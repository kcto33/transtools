<Window x:Class="ScreenTranslator.Windows.LongScreenshotPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource LongScreenshot_Label_Preview}"
        Width="320"
        Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowActivated="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="Transparent"
        AllowsTransparency="True">
  <Border Background="#E61F1F1F" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="6" Padding="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" BorderBrush="#55333333" BorderThickness="1" Background="#CC101010">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="40" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" BorderBrush="#33444444" BorderThickness="0,0,1,0" Background="#CC141414">
            <Image x:Name="StitchedImage" Stretch="Uniform" MouseLeftButtonDown="StitchedImage_MouseLeftButtonDown" Cursor="Hand" />
          </Border>

          <Canvas Grid.Column="1" x:Name="MarkerCanvas" Height="200" Margin="6,4" Background="#22222222" />
        </Grid>
      </Border>

      <TextBlock Grid.Row="1" x:Name="HintText" Margin="0,8,0,0" Foreground="#D8FFFFFF" TextWrapping="Wrap" />
    </Grid>
  </Border>
</Window>
