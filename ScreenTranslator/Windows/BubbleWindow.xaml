<Window x:Class="ScreenTranslator.Windows.BubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="False"
        Focusable="False">
  <Border x:Name="Chrome"
          Background="#F7F7F5"
          CornerRadius="8"
          BorderThickness="1"
          BorderBrush="#22000000"
          Padding="12">
    <Border.ToolTip>
      <ToolTip Background="Transparent"
               BorderThickness="0"
               Padding="0"
               HasDropShadow="False">
        <Border Background="#99333333"
                CornerRadius="4"
                Padding="8,5">
          <TextBlock Text="{DynamicResource Bubble_Tooltip}"
                     Foreground="White"
                     FontSize="12" />
        </Border>
      </ToolTip>
    </Border.ToolTip>
    <Grid>
      <TextBlock x:Name="TranslationText"
                 FontSize="14"
                 FontFamily="Segoe UI"
                 Foreground="#111111"
                 TextWrapping="Wrap" />
      <Border x:Name="CopyStatusBadge"
              Background="#99333333"
              CornerRadius="4"
              Padding="8,5"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="0,0,0,-34"
              Visibility="Collapsed">
        <TextBlock x:Name="CopyStatusText"
                   Text="{DynamicResource Bubble_CopyStatus}"
                   Foreground="White"
                   FontSize="12" />
      </Border>
    </Grid>
  </Border>
</Window>
