<Window x:Class="ScreenTranslator.Windows.FloatingNoteListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FloatingNoteList_Title}"
        Width="520"
        Height="420"
        MinWidth="380"
        MinHeight="280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">
  <Border x:Name="Chrome"
          Background="#FFF7CF"
          BorderBrush="#CDBE78"
          BorderThickness="2"
          CornerRadius="14">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="36" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="48" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            Background="Transparent"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border Background="#FFF0A8" CornerRadius="12,12,0,0" />
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
          <Button Content="-"
                  Width="28"
                  Height="28"
                  Padding="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="MinimizeButton_Click" />
          <Button Content="x"
                  Width="28"
                  Height="28"
                  Padding="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="CloseButton_Click" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="1"
                 Text="{DynamicResource FloatingNoteList_Title}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Margin="16,12,16,10" />

      <ListBox x:Name="NotesList"
               Grid.Row="2"
               Margin="16,0,16,0"
               BorderThickness="1"
               BorderBrush="#D8C987"
               Background="#FFFFFBEB"
               MouseDoubleClick="NotesList_MouseDoubleClick">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="10" BorderBrush="#EADC99" BorderThickness="0,0,0,1">
              <StackPanel>
                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding LastWriteTime}" FontSize="12" Foreground="#6F6844" />
                <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <StackPanel Grid.Row="3"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="16,8,16,10">
        <Button x:Name="RefreshButton"
                Content="{DynamicResource Btn_Refresh}"
                Margin="0,0,8,0"
                Padding="16,6"
                Background="#FFFFFBEB"
                BorderBrush="#D8C987"
                Click="RefreshButton_Click" />
        <Button x:Name="OpenButton"
                Content="{DynamicResource Btn_Open}"
                Padding="16,6"
                Background="#FFFFFBEB"
                BorderBrush="#D8C987"
                Click="OpenButton_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
