<Window x:Class="ScreenTranslator.Windows.FloatingNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Title="{DynamicResource TrayMenu_FloatingNote}"
        ResizeMode="CanResizeWithGrip"
        MinWidth="220"
        MinHeight="180"
        Width="306"
        Height="430">
  <Border x:Name="Chrome"
          Background="#FFF7CF"
          BorderBrush="#D8C987"
          BorderThickness="2"
          CornerRadius="14">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition x:Name="TitleRow" Height="34" />
        <RowDefinition Height="*" />
        <RowDefinition x:Name="ToolbarRow" Height="36" />
      </Grid.RowDefinitions>

      <Grid x:Name="TitleBar"
            Grid.Row="0"
            Background="Transparent"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border x:Name="TitleBarFill"
                Grid.ColumnSpan="3"
                Background="#FFF0A8"
                CornerRadius="12,12,0,0" />
        <Button x:Name="NewNoteButton"
                Grid.Column="0"
                Content="+"
                Width="34"
                Height="30"
                FontSize="20"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="NewNoteButton_Click"
                ToolTip="{DynamicResource FloatingNote_Tooltip_New}" />
        <StackPanel x:Name="TitleButtons"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0">
          <TextBlock x:Name="PinnedIndicator"
                     Text="●"
                     Foreground="#7A6B21"
                     FontSize="10"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <Button x:Name="ListButton"
                  Content="≡"
                  Width="28"
                  Height="28"
                  Padding="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="ListButton_Click"
                  ToolTip="{DynamicResource FloatingNote_Tooltip_List}" />
          <Button x:Name="MoreButton"
                  Content="..."
                  Width="28"
                  Height="28"
                  Padding="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="MoreButton_Click"
                  ToolTip="{DynamicResource FloatingNote_Tooltip_More}" />
          <Button x:Name="CloseButton"
                  Content="x"
                  Width="28"
                  Height="28"
                  Padding="0"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="CloseButton_Click" />
        </StackPanel>
      </Grid>

      <RichTextBox x:Name="NoteEditor"
                   Grid.Row="1"
                   AcceptsTab="True"
                   BorderThickness="0"
                   Background="Transparent"
                   Padding="12"
                   FontFamily="Segoe UI"
                   FontSize="14"
                   VerticalScrollBarVisibility="Auto"
                   SelectionChanged="NoteEditor_SelectionChanged" />

      <Border x:Name="Toolbar"
              Grid.Row="2"
              BorderBrush="#EADC99"
              BorderThickness="0,1,0,0"
              Background="#FFFFF2DA"
              CornerRadius="0,0,12,12">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0,8,0">
          <ToggleButton x:Name="BoldButton"
                        Content="B"
                        FontWeight="Bold"
                        Width="34"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BoldButton_Click"
                        ToolTip="{DynamicResource FloatingNote_Tooltip_Bold}" />
          <ToggleButton x:Name="ItalicButton"
                        Content="I"
                        FontStyle="Italic"
                        Width="34"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ItalicButton_Click"
                        ToolTip="{DynamicResource FloatingNote_Tooltip_Italic}" />
          <ToggleButton x:Name="UnderlineButton"
                        Width="34"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="UnderlineButton_Click"
                        ToolTip="{DynamicResource FloatingNote_Tooltip_Underline}">
            <TextBlock Text="U" TextDecorations="Underline" />
          </ToggleButton>
          <ToggleButton x:Name="StrikeButton"
                        Width="40"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="StrikeButton_Click"
                        ToolTip="{DynamicResource FloatingNote_Tooltip_Strike}">
            <TextBlock Text="ab" TextDecorations="Strikethrough" />
          </ToggleButton>
          <Button x:Name="BulletButton"
                  Content="≡"
                  Width="34"
                  Height="28"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="BulletButton_Click"
                  ToolTip="{DynamicResource FloatingNote_Tooltip_Bullets}" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
