<Window x:Class="ScreenTranslator.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#66000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Focusable="True">
  <Grid>
    <Canvas x:Name="RootCanvas">
      <Rectangle x:Name="SelectionRect"
                 Fill="#2200B7FF"
                 Stroke="#FF00B7FF"
                 StrokeThickness="2"
                 Visibility="Collapsed" />
    </Canvas>
  </Grid>
</Window>
