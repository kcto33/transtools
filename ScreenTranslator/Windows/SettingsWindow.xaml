<Window x:Class="ScreenTranslator.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="160" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider" VerticalAlignment="Center" />
    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ProviderCombo" MinWidth="240" />

    <TextBlock Grid.Row="1" Grid.Column="0" Text="From" VerticalAlignment="Center" Margin="0,10,0,0" />
    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="FromLangCombo" Margin="0,10,0,0" />

    <TextBlock Grid.Row="2" Grid.Column="0" Text="To" VerticalAlignment="Center" Margin="0,10,0,0" />
    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ToLangCombo" Margin="0,10,0,0" />

    <!-- Generic single-key providers -->
    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="KeyLabel" Text="API Key" VerticalAlignment="Center" Margin="0,10,0,0" />
    <Grid Grid.Row="3" Grid.Column="1" x:Name="KeyRow" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <PasswordBox x:Name="KeyPassword" Grid.Column="0" />
      <TextBox x:Name="KeyText" Grid.Column="0" Visibility="Collapsed" />

      <CheckBox x:Name="ShowKeyCheck" Grid.Column="1" Content="Show" Margin="10,0,0,0" VerticalAlignment="Center" />
      <Button x:Name="ClearKeyButton" Grid.Column="2" Content="Clear" Margin="10,0,0,0" Padding="12,4" />
    </Grid>

    <!-- Youdao: app id + secret -->
    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="YoudaoAppIdLabel" Text="Youdao AppId" VerticalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed" />
    <TextBox Grid.Row="4" Grid.Column="1" x:Name="YoudaoAppIdText" Margin="0,10,0,0" Visibility="Collapsed" />

    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="YoudaoSecretLabel" Text="Youdao Secret" VerticalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed" />
    <Grid Grid.Row="5" Grid.Column="1" x:Name="YoudaoSecretRow" Margin="0,10,0,0" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <PasswordBox x:Name="YoudaoSecretPassword" Grid.Row="0" Grid.Column="0" />
      <TextBox x:Name="YoudaoSecretText" Grid.Row="0" Grid.Column="0" Visibility="Collapsed" />

      <CheckBox x:Name="YoudaoShowSecretCheck" Grid.Row="0" Grid.Column="1" Content="Show" Margin="10,0,0,0" VerticalAlignment="Center" />
      <Button x:Name="YoudaoClearSecretButton" Grid.Row="0" Grid.Column="2" Content="Clear" Margin="10,0,0,0" Padding="12,4" />

      <TextBlock x:Name="YoudaoSecretHint"
                 Grid.Row="1"
                 Grid.Column="0"
                 Grid.ColumnSpan="3"
                 Text="Secret saved (not shown). Leave empty to keep it."
                 Foreground="#666"
                 FontSize="11"
                 Margin="0,6,0,0"
                 Visibility="Collapsed" />
    </Grid>

    <TextBlock Grid.Row="6" Grid.Column="0" x:Name="EndpointLabel" Text="Endpoint" VerticalAlignment="Center" Margin="0,10,0,0" />
    <TextBox Grid.Row="6" Grid.Column="1" x:Name="EndpointText" Margin="0,10,0,0" />

    <TextBlock Grid.Row="7" Grid.Column="0" x:Name="RegionLabel" Text="Region" VerticalAlignment="Center" Margin="0,10,0,0" />
    <TextBox Grid.Row="7" Grid.Column="1" x:Name="RegionText" Margin="0,10,0,0" />

    <TextBlock Grid.Row="8" Grid.Column="0" Text="Hotkey" VerticalAlignment="Center" Margin="0,10,0,0" />
    <TextBox Grid.Row="8" Grid.Column="1" x:Name="HotkeyText" Margin="0,10,0,0" ToolTip="Example: Ctrl+Alt+T" />

    <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Margin="0,12,0,0" Foreground="#444">
      Keys are stored locally using Windows DPAPI (CurrentUser). Exporting settings.json will not reveal plain keys.
    </TextBlock>

    <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="SaveButton" Content="Save" Padding="18,6" />
    </StackPanel>
  </Grid>
</Window>
