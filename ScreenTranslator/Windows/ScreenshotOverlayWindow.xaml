<Window x:Class="ScreenTranslator.Windows.ScreenshotOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Focusable="True">
  <Window.Resources>
    <Style x:Key="ToolbarButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="Margin" Value="2,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#55FFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#33FFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Image x:Name="BackgroundImage" Stretch="None" />

    <Canvas x:Name="OverlayCanvas">
      <Path x:Name="DarkOverlay" Fill="#66000000" />
    </Canvas>

    <Canvas x:Name="SelectionCanvas">
      <Rectangle x:Name="SelectionRect"
                 Stroke="#FF00B7FF"
                 StrokeThickness="2"
                 Fill="Transparent"
                 Visibility="Collapsed" />

      <Border x:Name="SizeIndicator"
              Background="#CC000000"
              CornerRadius="3"
              Padding="6,3"
              Visibility="Collapsed">
        <TextBlock x:Name="SizeText"
                   Foreground="White"
                   FontSize="12"
                   FontFamily="Consolas" />
      </Border>

      <Border x:Name="Toolbar"
              Background="#EE333333"
              CornerRadius="4"
              Padding="4"
              Visibility="Collapsed">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="BtnPin" Content="{DynamicResource Screenshot_Pin}" Style="{StaticResource ToolbarButton}" Click="BtnPin_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Pin}" />
          <Button x:Name="BtnCopy" Content="{DynamicResource Screenshot_Copy}" Style="{StaticResource ToolbarButton}" Click="BtnCopy_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Copy}" />
          <Button x:Name="BtnSave" Content="{DynamicResource Screenshot_Save}" Style="{StaticResource ToolbarButton}" Click="BtnSave_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Save}" />
          <Button x:Name="BtnLongScreenshot" Content="{DynamicResource Screenshot_Long}" Style="{StaticResource ToolbarButton}" Click="BtnLongScreenshot_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Long}" />
          <Button x:Name="BtnFreeform" Content="{DynamicResource Screenshot_Freeform}" Style="{StaticResource ToolbarButton}" Click="BtnFreeform_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Freeform}" />
          <Button x:Name="BtnCancel" Content="{DynamicResource Screenshot_Cancel}" Style="{StaticResource ToolbarButton}" Click="BtnCancel_Click" ToolTip="{DynamicResource Screenshot_Tooltip_Cancel}" />
        </StackPanel>
      </Border>
    </Canvas>
  </Grid>
</Window>
